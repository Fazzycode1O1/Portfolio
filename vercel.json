{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "buildCommand": "next build",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "src/app/api/auth/login/route.ts": { "maxDuration": 10 },
    "src/app/api/contact/route.ts":    { "maxDuration": 10 },
    "src/app/api/upload/route.ts":     { "maxDuration": 30 },
    "src/app/api/github/stats/route.ts": { "maxDuration": 15 }
  },
  "crons": []
}
